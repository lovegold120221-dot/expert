{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/eburon/alpha:latest",
  "instructions": [
    "AGENTS.md",
    ".agents/AGENTS.md"
  ],
  "skills": {
    "paths": [
      "./.agents/skills",
      "~/.agents/skills"
    ]
  },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "eburon/alpha:latest": {
          "name": "eburon/alpha:latest"
        }
      }
    }
  }
}
